FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    poppler-utils \
    mupdf-tools \
    evince \
    strace \
    xvfb \
    procps \
    coreutils \
    && rm -rf /var/lib/apt/lists/*

RUN useradd -r -u 10001 -g users sandbox

WORKDIR /app
COPY sandbox/analyze_inside.py /app/analyze_inside.py

USER sandbox